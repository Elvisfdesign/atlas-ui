{
  "name": "atlas-workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "npm run dev --workspace=atlas-ui",
    "dev:app": "npm run dev --workspace=atlas-intelligence",
    "storybook": "npm run storybook --workspace=atlas-ui",
    "build": "npm run build:ui && npm run build:app",
    "build:ui": "npm run build --workspace=atlas-ui",
    "build:app": "npm run build --workspace=atlas-intelligence",
    "build-storybook": "npm run build-storybook --workspace=atlas-ui",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  }
}
